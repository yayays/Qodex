{
  "name": "qodex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/qodex-edge",
    "packages/qodex-channel-qqbot"
  ],
  "scripts": {
    "build:core": "cargo build -p qodex-core",
    "run:core": "cargo run -p qodex-core -- --config ./qodex.toml",
    "check:core": "cargo check -p qodex-core",
    "build:edge": "npm --workspace @qodex/edge run build",
    "check:edge": "npm --workspace @qodex/edge run check",
    "dev:edge": "npm --workspace @qodex/edge run dev",
    "host:qodex": "npm --workspace @qodex/edge run host --",
    "build:qqbot": "npm --workspace @qodex/channel-qqbot run build",
    "check:qqbot": "npm --workspace @qodex/channel-qqbot run check"
  }
}
