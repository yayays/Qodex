{
  "name": "qodex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/qodex-edge",
    "packages/qodex-channel-qqbot",
    "packages/qodex-clawbot-bridge"
  ],
  "scripts": {
    "generate:contracts": "node ./scripts/generate-contract-artifacts.mjs",
    "build:core": "cargo build -p qodex-core",
    "run:core": "cargo run -p qodex-core -- --config ./qodex.toml",
    "check:core": "cargo check -p qodex-core",
    "build:edge": "npm --workspace @qodex/edge run build",
    "check:edge": "npm --workspace @qodex/edge run check",
    "dev:edge": "npm --workspace @qodex/edge run dev",
    "host:qodex": "npm --workspace @qodex/edge run host --",
    "start:qodex": "npm run host:qodex -- --config ./qodex.toml",
    "start:qodex:skip-backend": "npm run host:qodex -- --config ./qodex.toml --skip-app-server",
    "quick:start": "node ./scripts/qodex-quick-start.mjs",
    "doctor:qodex": "node ./scripts/qodex-doctor.mjs",
    "status:qodex": "node ./scripts/qodex-status.mjs",
    "build:qqbot": "npm --workspace @qodex/channel-qqbot run build",
    "check:qqbot": "npm --workspace @qodex/channel-qqbot run check",
    "build:clawbot-bridge": "npm --workspace @qodex/clawbot-bridge run build",
    "check:clawbot-bridge": "npm --workspace @qodex/clawbot-bridge run check"
  }
}
